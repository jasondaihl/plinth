{
  "name": "@plinth/tokens",
  "version": "0.0.0",
  "description": "Three-layer design tokens for Plinth: primitive, semantic, brand.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./css/primitive": "./dist/primitive.css",
    "./css/semantic": "./dist/semantic.css",
    "./css/brand": "./dist/brand.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc && tsx scripts/build.ts",
    "dev": "tsx scripts/build.ts --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@plinth/eslint-config": "workspace:*",
    "@plinth/tsconfig": "workspace:*",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
